<?xml version="1.0" encoding="utf-8"?>
<!--
  Transformacion aplicada en modo Release (despliegue Azure).
  Las cadenas de conexion REALES se configuran directamente en el
  portal de Azure App Service → Configuracion → Cadenas de conexion.
  Este archivo solo elimina el modo debug y activa errores genericos.
-->
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">

  <system.web>
    <!-- Quitar modo debug en produccion -->
    <compilation xdt:Transform="RemoveAttributes(debug)" />
    <!-- Mostrar pagina generica de error al usuario final (no exponer stack trace) -->
    <customErrors mode="Off" xdt:Transform="Replace"/>
  </system.web>

</configuration>
